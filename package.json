{
  "name": "frettrack",
  "version": "0.2.9-beta.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check:plan-branding": "node scripts/check-plan-branding.mjs",
    "check:permissions": "node scripts/check-permission-hardening.mjs && node scripts/check-rpc-security.mjs",
    "check:tiers": "node scripts/check-tier-split.mjs",
    "check:landing-worker": "node scripts/check-landing-worker.mjs",
    "check:migrations": "node scripts/check-supabase-migrations.mjs",
    "migration:check": "node scripts/check-supabase-migrations.mjs",
    "migration:check:strict": "node scripts/check-supabase-migrations.mjs --strict",
    "backup:supabase": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup-hosted-supabase.ps1",
    "db:local:refresh-from-backup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/refresh-local-db-from-hosted-backup.ps1",
    "db:local:apply": "node scripts/apply-local-migrations.mjs",
    "seed:local-test-shops": "node scripts/seed-local-test-shops.mjs --reset",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "heic2any": "^0.0.4",
    "jsbarcode": "^3.12.3",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.16"
  }
}
